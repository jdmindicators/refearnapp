---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/competitors';

const PRO_PRICE = 199;
---

<Layout
  title="One-Time Payment Affiliate Software — Lifetime Deal Alternatives to Monthly Subscriptions"
  description="Stop paying monthly for affiliate tracking. RefearnApp is a one-time payment lifetime deal alternative to Rewardful, FirstPromoter, Tolt and more. Pay once, own it forever."
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-24">
    <div class="mt-8 mb-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-green-50 border border-green-200 px-4 py-1.5 text-sm font-semibold text-green-700">
        💰 One-Time Payment · Lifetime Deal · No Subscription
      </div>
      <h1 class="mt-4 mb-6 text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        Affiliate Software<br />
        <span class="text-green-600">You Pay For Once</span>
      </h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-slate-600">
        Every major affiliate tool charges you monthly — forever. RefearnApp is the
        <strong>one-time payment lifetime deal</strong> alternative. Pay $199 once,
        run your affiliate program forever.
      </p>
    </div>

    <!-- All competitor cards -->
    <div class="mb-20 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {competitors.map((c) => {
        const year1Save = c.annualPrice - PRO_PRICE;
        return (
          <a
            href={`/one-time-alternative/${c.slug}`}
            class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-indigo-400 hover:shadow-md transition-all"
          >
            <div class="mb-3 flex items-center justify-between">
              <h3 class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">{c.name} Alternative</h3>
              <span class="rounded-full bg-red-50 px-2 py-0.5 text-xs font-semibold text-red-500">{c.price}</span>
            </div>
            <p class="mb-4 text-sm text-slate-500">One-time payment alternative with lifetime access</p>
            {year1Save > 0 && (
              <div class="rounded-lg bg-green-50 border border-green-100 px-3 py-2 text-center">
                <span class="text-sm font-bold text-green-600">Save ${year1Save.toLocaleString()} in year 1</span>
              </div>
            )}
          </a>
        );
      })}
    </div>

    <!-- CTA -->
    <div class="rounded-3xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-10 text-center shadow-2xl">
      <h2 class="mb-4 text-3xl font-extrabold text-white">Ready to Stop Paying Monthly?</h2>
      <p class="mb-8 text-indigo-200 text-lg">One payment. Lifetime access. Open-source & self-hostable.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/#pricing" class="rounded-xl bg-white px-8 py-4 text-lg font-bold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-lg">
          Get Pro — $199 Lifetime
        </a>
        <a href="/#pricing" class="rounded-xl border border-indigo-400 px-8 py-4 text-lg font-semibold text-white hover:bg-indigo-700 transition-colors">
          Get Ultimate — $299 Lifetime
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/competitors';
import PricingCTA from '../../components/blog/PricingCTA';

export async function getStaticPaths() {
  return competitors.map((c) => ({
    params: { competitor: c.slug },
    props: { info: c },
  }));
}

const { info } = Astro.props;

const otherCompetitors = competitors
  .filter((c) => c.slug !== info.slug)
  .slice(0, 8);

const PRO_PRICE = 199;
const ULTIMATE_PRICE = 299;
const year1SavePro = info.annualPrice - PRO_PRICE;
const year2SavePro = info.annualPrice * 2 - PRO_PRICE;
const year3SavePro = info.annualPrice * 3 - PRO_PRICE;
const year1SaveUltimate = info.annualPrice - ULTIMATE_PRICE;
const year2SaveUltimate = info.annualPrice * 2 - ULTIMATE_PRICE;
const year3SaveUltimate = info.annualPrice * 3 - ULTIMATE_PRICE;

const checkIcon = `<svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>`;
const crossIcon = `<svg class="w-5 h-5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>`;
---

<Layout
  title={`${info.name} Alternative with One-Time Payment (Lifetime Deal) — RefearnApp`}
  description={`Stop paying ${info.price} forever. Switch to RefearnApp — a one-time payment ${info.name} alternative. Pay once, own it forever. Open-source & self-hostable.`}
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-24">

    <!-- Hero -->
    <div class="mt-8 mb-16 text-center">
      <nav class="mb-4 text-sm text-slate-400">
        <a href="/" class="hover:text-primary">Home</a> /
        <a href={`/alternative/${info.slug}`} class="hover:text-primary">{info.name} Alternative</a> /
        <span class="font-medium text-slate-600">One-Time Payment</span>
      </nav>

      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-green-50 border border-green-200 px-4 py-1.5 text-sm font-semibold text-green-700">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        One-Time Payment · No Subscription · Lifetime Deal
      </div>

      <h1 class="mt-4 mb-6 text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        The <span class="text-primary">{info.name} Alternative</span><br />
        You Pay For <span class="text-green-600">Once</span>
      </h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-slate-600">
        {info.name} charges <strong>{info.price}</strong> — forever. RefearnApp is a one-time payment lifetime deal.
        Pay <strong>$199 once</strong>, get affiliate tracking forever. No monthly bills, no revenue caps, no lock-in.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/#pricing" class="rounded-xl bg-indigo-600 px-8 py-4 text-lg font-bold text-white hover:bg-indigo-700 transition-colors shadow-lg">
          Get Lifetime Deal — $199
        </a>
        <a href="/alternative/{info.slug}" class="rounded-xl border border-slate-200 px-8 py-4 text-lg font-semibold text-slate-600 hover:border-indigo-400 hover:text-indigo-600 transition-colors">
          See Full Comparison →
        </a>
      </div>
    </div>

    <!-- Savings Calculator -->
    <div class="mb-20 rounded-3xl border border-indigo-100 bg-gradient-to-br from-indigo-50 to-slate-50 p-8 md:p-12 shadow-xl">
      <div class="mb-8 text-center">
        <h2 class="text-3xl font-extrabold text-slate-900">
          💰 How Much Do You Save vs {info.name}?
        </h2>
        <p class="mt-2 text-slate-500">
          {info.name} costs <strong>{info.price}</strong> ({info.annualPrice > 0 ? `$${info.annualPrice}/year` : 'expensive'}). Here's what you save with RefearnApp's lifetime deal.
        </p>
      </div>

      <!-- Year Tabs -->
      <div class="mb-8 flex justify-center">
        <div class="inline-flex rounded-xl border border-slate-200 bg-white p-1 shadow-sm" id="year-tabs">
          <button data-year="1" class="year-tab active-tab rounded-lg px-5 py-2 text-sm font-semibold transition-all">Year 1</button>
          <button data-year="2" class="year-tab rounded-lg px-5 py-2 text-sm font-semibold transition-all text-slate-500 hover:text-slate-700">Year 2</button>
          <button data-year="3" class="year-tab rounded-lg px-5 py-2 text-sm font-semibold transition-all text-slate-500 hover:text-slate-700">Year 3</button>
        </div>
      </div>

      <!-- Calculator Cards -->
      <div class="grid gap-6 md:grid-cols-2">

        <!-- Pro Plan -->
        <div class="rounded-2xl border border-indigo-200 bg-white p-6 shadow-sm">
          <div class="mb-4 flex items-center justify-between">
            <h3 class="text-lg font-bold text-slate-900">Pro Plan</h3>
            <span class="rounded-full bg-indigo-100 px-3 py-1 text-sm font-bold text-indigo-700">$199 once</span>
          </div>
          <ul class="mb-6 space-y-2 text-sm text-slate-600">
            <li class="flex items-center gap-2" set:html={`${checkIcon} Unlimited affiliates & revenue`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Coupon code tracking`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Stripe & Paddle tracking`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} PayPal mass payout`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} White label customization`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Custom domain`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} 1 affiliate program`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} 3 team members`} />
          </ul>
          <div class="rounded-xl bg-green-50 border border-green-200 p-4 text-center">
            <p class="text-sm text-slate-500">You save vs {info.name}</p>
            <p class="text-4xl font-extrabold text-green-600" id="pro-savings" data-year1="${year1SavePro}" data-year2="${year2SavePro}" data-year3="${year3SavePro}">
              ${year1SavePro > 0 ? `$${year1SavePro.toLocaleString()}` : 'Instant savings'}
            </p>
            <p class="text-xs text-slate-400 mt-1" id="pro-label">in year 1</p>
          </div>
        </div>

        <!-- Ultimate Plan -->
        <div class="rounded-2xl border-2 border-indigo-500 bg-white p-6 shadow-lg">
          <div class="mb-3">
            <span class="rounded-full bg-indigo-600 px-3 py-1 text-xs font-bold text-white">BEST VALUE</span>
          </div>
          <div class="mb-4 flex items-center justify-between">
            <h3 class="text-lg font-bold text-slate-900">Ultimate Plan</h3>
            <span class="rounded-full bg-indigo-100 px-3 py-1 text-sm font-bold text-indigo-700">$299 once</span>
          </div>
          <ul class="mb-6 space-y-2 text-sm text-slate-600">
            <li class="flex items-center gap-2" set:html={`${checkIcon} Everything in Pro`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Unlimited affiliate programs`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Unlimited team members`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Open-source (AGPL v3)`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Self-hostable`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Data sovereignty`} />
            <li class="flex items-center gap-2" set:html={`${checkIcon} Priority support`} />
          </ul>
          <div class="rounded-xl bg-green-50 border border-green-200 p-4 text-center">
            <p class="text-sm text-slate-500">You save vs {info.name}</p>
            <p class="text-4xl font-extrabold text-green-600" id="ultimate-savings" data-year1="${year1SaveUltimate}" data-year2="${year2SaveUltimate}" data-year3="${year3SaveUltimate}">
              ${year1SaveUltimate > 0 ? `$${year1SaveUltimate.toLocaleString()}` : 'Instant savings'}
            </p>
            <p class="text-xs text-slate-400 mt-1" id="ultimate-label">in year 1</p>
          </div>
        </div>
      </div>

      <!-- Cumulative cost comparison bar -->
      <div class="mt-8 rounded-2xl bg-white border border-slate-200 p-6">
        <h4 class="mb-4 font-bold text-slate-900 text-center">Cost Over Time</h4>
        <div class="space-y-4">
          <div>
            <div class="mb-1 flex justify-between text-sm">
              <span class="font-semibold text-slate-600">{info.name} (subscription)</span>
              <span class="font-bold text-red-500" id="competitor-cost">${info.annualPrice.toLocaleString()}/yr</span>
            </div>
            <div class="h-4 rounded-full bg-red-100 overflow-hidden">
              <div class="h-4 rounded-full bg-red-400 transition-all duration-500" id="competitor-bar" style="width: 100%"></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex justify-between text-sm">
              <span class="font-semibold text-slate-600">RefearnApp Pro (one-time)</span>
              <span class="font-bold text-green-600">$199 total</span>
            </div>
            <div class="h-4 rounded-full bg-green-100 overflow-hidden">
              <div class="h-4 rounded-full bg-green-500 transition-all duration-500" id="pro-bar" style={`width: ${Math.min(100, (PRO_PRICE / info.annualPrice) * 100)}%`}></div>
            </div>
          </div>
          <div>
            <div class="mb-1 flex justify-between text-sm">
              <span class="font-semibold text-slate-600">RefearnApp Ultimate (one-time)</span>
              <span class="font-bold text-green-600">$299 total</span>
            </div>
            <div class="h-4 rounded-full bg-indigo-100 overflow-hidden">
              <div class="h-4 rounded-full bg-indigo-500 transition-all duration-500" id="ultimate-bar" style={`width: ${Math.min(100, (ULTIMATE_PRICE / info.annualPrice) * 100)}%`}></div>
            </div>
          </div>
        </div>
        <p class="mt-4 text-center text-xs text-slate-400" id="bar-note">Bar width shows cost relative to {info.name}'s year 1 spend</p>
      </div>
    </div>

    <!-- Problem vs Solution -->
    <div class="mb-20 grid gap-6 md:grid-cols-2 md:gap-8">
      <div class="rounded-2xl border border-red-100 bg-red-50 p-6 shadow-sm md:p-8">
        <h3 class="mb-4 text-xl font-bold text-red-700">
          The {info.name} Subscription Trap
        </h3>
        <ul class="space-y-4 text-red-900/80">
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            {info.weakness}
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            You pay {info.price} every single month — even when you're not growing.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            Prices can increase anytime and you have no choice but to pay or lose access.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            Your affiliate data is hostage — no self-hosting option.
          </li>
        </ul>
      </div>

      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-6 shadow-sm md:p-8">
        <h3 class="mb-4 text-xl font-bold text-blue-700">
          RefearnApp — Pay Once, Own Forever
        </h3>
        <ul class="space-y-4 text-blue-900/80">
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            One-time payment — $199 Pro or $299 Ultimate. Never pay again.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            Unlimited affiliates and revenue on every plan — no caps, ever.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            Open-source (AGPL v3) — inspect the code, fork it, own it.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            Self-hostable — migrate to your own servers anytime you want.
          </li>
        </ul>
      </div>
    </div>

    <!-- Feature Comparison Table -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-extrabold text-slate-900">
        {info.name} vs RefearnApp — Full Comparison
      </h2>
      <div class="overflow-x-auto rounded-3xl border border-slate-200 bg-white shadow-xl">
        <table class="w-full min-w-[700px] border-collapse text-left text-sm md:text-base">
          <thead>
          <tr class="border-b border-slate-200 bg-slate-50/50">
            <th class="p-6 font-bold tracking-wider text-slate-500 uppercase">Feature</th>
            <th class="p-6 font-bold tracking-wider text-slate-400 uppercase">{info.name}</th>
            <th class="bg-indigo-50/50 p-6 font-bold tracking-wider text-indigo-600 uppercase">RefearnApp</th>
          </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
          <tr>
            <td class="p-6 font-semibold text-slate-900">Pricing Model</td>
            <td class="p-6 text-red-500 font-semibold">{info.price} subscription</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-green-700">$199 one-time (lifetime)</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">3-Year Total Cost</td>
            <td class="p-6 text-red-500 font-bold">${(info.annualPrice * 3).toLocaleString()}</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-green-700">$199 — nothing more</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Unlimited Affiliates</td>
            <td class="p-6 text-slate-500">Limited on lower tiers</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-indigo-700" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Revenue Caps</td>
            <td class="p-6 text-red-500">Capped — pay more as you grow</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-green-600">No caps ever</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Coupon Code Tracking</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Stripe & Paddle Support</td>
            <td class="p-6 text-slate-500">Stripe only or expensive add-on</td>
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">PayPal Mass Payout</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">White Label & Custom Domain</td>
            <td class="p-6 text-slate-500">Enterprise add-on</td>
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Software License</td>
            <td class="p-6 text-slate-500">Proprietary (Closed)</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-indigo-700">Open Source (AGPL v3)</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Self-Hosting</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Data Sovereignty</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-slate-400 italic md:hidden">← Swipe to compare →</p>
    </div>

    <!-- FAQ -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-extrabold text-slate-900">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {[
          {
            q: `Is RefearnApp really a one-time payment alternative to ${info.name}?`,
            a: `Yes. RefearnApp Pro is $199 once and RefearnApp Ultimate is $299 once. You pay once and get lifetime access — no monthly fees, no annual renewals. Compare that to ${info.name} which costs ${info.price} every month.`
          },
          {
            q: `Is this a lifetime deal or does it expire?`,
            a: `It is a true lifetime deal. One payment gives you permanent access to RefearnApp including all future updates on your plan. There is no expiry date and no hidden renewal fee.`
          },
          {
            q: `How much do I save vs ${info.name} over 3 years?`,
            a: `${info.name} costs $${info.annualPrice} per year — that's $${(info.annualPrice * 3).toLocaleString()} over 3 years. RefearnApp Pro is $199 once, saving you $${(info.annualPrice * 3 - PRO_PRICE).toLocaleString()} over the same period.`
          },
          {
            q: `Can I self-host RefearnApp like I would with an open-source tool?`,
            a: `Yes. RefearnApp is open-source (AGPL v3) and fully self-hostable. Start on our managed cloud for instant setup, then migrate to your own servers whenever you want. Your data stays yours.`
          },
          {
            q: `Does RefearnApp support Stripe and Paddle like ${info.name}?`,
            a: `RefearnApp natively supports both Stripe and Paddle on all plans. It also supports coupon code tracking so affiliates can share discount codes instead of just tracking links.`
          },
        ].map((faq) => (
          <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-slate-900 list-none">
              {faq.q}
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <p class="mt-4 text-slate-600 leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- Interlinked one-time pages -->
    <div class="mb-20">
      <h3 class="mb-4 text-center text-xl font-bold text-slate-900">
        More One-Time Payment Alternatives
      </h3>
      <p class="mb-8 text-center text-slate-500 text-sm">See how much you save vs other subscription tools</p>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        {otherCompetitors.map((c) => (
          <a
            href={`/one-time-alternative/${c.slug}`}
            class="flex flex-col items-center justify-center rounded-xl border border-slate-200 bg-white p-4 text-center text-sm font-semibold text-slate-600 transition-all hover:border-indigo-600 hover:text-indigo-600 hover:shadow-sm"
          >
            <span>{c.name}</span>
            <span class="mt-1 text-xs font-normal text-red-400">{c.price}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mb-24 rounded-3xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-10 text-center shadow-2xl">
      <h2 class="mb-4 text-3xl font-extrabold text-white md:text-4xl">
        Stop Paying {info.price} Every Month
      </h2>
      <p class="mb-8 text-indigo-200 text-lg">
        Join founders who chose to pay once and own their affiliate tracking forever.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/#pricing" class="rounded-xl bg-white px-8 py-4 text-lg font-bold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-lg">
          Get Pro — $199 Lifetime
        </a>
        <a href="/#pricing" class="rounded-xl border border-indigo-400 px-8 py-4 text-lg font-semibold text-white hover:bg-indigo-700 transition-colors">
          Get Ultimate — $299 Lifetime
        </a>
      </div>
      <p class="mt-6 text-indigo-300 text-sm">Open-source · Self-hostable · No revenue caps · No lock-in</p>
    </div>

  </main>

  <Footer />
</Layout>

<script define:vars={{ year1SavePro, year2SavePro, year3SavePro, year1SaveUltimate, year2SaveUltimate, year3SaveUltimate, annualPrice: info.annualPrice, PRO_PRICE, ULTIMATE_PRICE }}>
  const tabs = document.querySelectorAll('.year-tab');
  const proSavings = document.getElementById('pro-savings');
  const ultimateSavings = document.getElementById('ultimate-savings');
  const proLabel = document.getElementById('pro-label');
  const ultimateLabel = document.getElementById('ultimate-label');
  const competitorCost = document.getElementById('competitor-cost');
  const competitorBar = document.getElementById('competitor-bar');
  const proBar = document.getElementById('pro-bar');
  const ultimateBar = document.getElementById('ultimate-bar');
  const barNote = document.getElementById('bar-note');

  const savings = {
    pro: { 1: year1SavePro, 2: year2SavePro, 3: year3SavePro },
    ultimate: { 1: year1SaveUltimate, 2: year2SaveUltimate, 3: year3SaveUltimate },
    competitorTotal: { 1: annualPrice, 2: annualPrice * 2, 3: annualPrice * 3 },
  };

  function updateCalculator(year) {
    const proSave = savings.pro[year];
    const ultimateSave = savings.ultimate[year];
    const compTotal = savings.competitorTotal[year];

    proSavings.textContent = proSave > 0 ? `$${proSave.toLocaleString()}` : 'Pays off instantly';
    ultimateSavings.textContent = ultimateSave > 0 ? `$${ultimateSave.toLocaleString()}` : 'Pays off instantly';

    const yearLabel = year === 1 ? 'in year 1' : `over ${year} years`;
    proLabel.textContent = yearLabel;
    ultimateLabel.textContent = yearLabel;

    competitorCost.textContent = `$${compTotal.toLocaleString()} total`;
    const proWidth = Math.min(100, (PRO_PRICE / compTotal) * 100);
    const ultimateWidth = Math.min(100, (ULTIMATE_PRICE / compTotal) * 100);
    proBar.style.width = `${proWidth}%`;
    ultimateBar.style.width = `${ultimateWidth}%`;
    barNote.textContent = `Bar width shows cost relative to ${year} year${year > 1 ? 's' : ''} of subscription spend`;
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('active-tab', 'bg-indigo-600', 'text-white');
        t.classList.add('text-slate-500');
      });
      tab.classList.add('active-tab', 'bg-indigo-600', 'text-white');
      tab.classList.remove('text-slate-500');
      updateCalculator(parseInt(tab.dataset.year));
    });
  });

  // Set initial active tab style
  const firstTab = document.querySelector('[data-year="1"]');
  if (firstTab) {
    firstTab.classList.add('bg-indigo-600', 'text-white');
  }
</script>

<style>
    .year-tab { cursor: pointer; }
    .active-tab { background-color: #4f46e5; color: white; }
    details summary::-webkit-details-marker { display: none; }
</style>
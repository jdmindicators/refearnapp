---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/competitors';

export async function getStaticPaths() {
  return competitors.map((c) => ({
    params: { competitor: c.slug },
    props: { info: c },
  }));
}

const { info } = Astro.props;

const otherCompetitors = competitors
  .filter((c) => c.slug !== info.slug)
  .slice(0, 8);

const checkIcon = `<svg class="w-5 h-5 text-indigo-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>`;
const crossIcon = `<svg class="w-5 h-5 text-red-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"></path></svg>`;

// FIX 2: removed "modify/extend" language — replaced with transparency/control framing
const freedomItems = [
  { id: 'inspect', label: 'I want to inspect the source code before trusting it with my affiliate data' },
  { id: 'selfhost', label: 'I want to self-host on my own servers without relying on a third party' },
  { id: 'lockin', label: 'I want to avoid vendor lock-in so I can leave or switch freely anytime' },
  { id: 'ownership', label: 'I want full data ownership — no third party holding my affiliate data hostage' },
  { id: 'transparency', label: 'I want full transparency — know exactly how tracking, payouts and attribution work under the hood' },
];
---

<Layout
  title={`Open Source ${info.name} Alternative — RefearnApp (AGPL v3, Self-Hostable)`}
  description={`Looking for an open source alternative to ${info.name}? RefearnApp is fully open source under AGPL v3. Inspect the code, self-host, own your data. No black box, no lock-in.`}
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-24">

    <!-- FIX 4: added mt-8 to push breadcrumb away from navigation -->
    <div class="mt-8 mb-16 text-center">
      <nav class="mb-4 text-sm text-slate-400">
        <a href="/" class="hover:text-primary">Home</a> /
        <a href="/open-source-alternative" class="hover:text-primary">Open Source Alternatives</a> /
        <span class="font-medium text-slate-600">{info.name}</span>
      </nav>

      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-indigo-50 border border-indigo-200 px-4 py-1.5 text-sm font-semibold text-indigo-700">
        🔓 Open Source · AGPL v3 · Self-Hostable · Full Code Access
      </div>

      <h1 class="mt-4 mb-6 text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        The Open Source<br />
        <span class="text-primary">{info.name} Alternative</span>
      </h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-slate-600">
        {info.name} is a closed-source black box — you can't see the code, you can't move your data freely.
        RefearnApp is <strong>fully open source under AGPL v3</strong>. Inspect it, deploy it on your own servers, own your data completely.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://github.com/ZAK123DSFDF/refearnapp" target="_blank" rel="noopener noreferrer"
           class="rounded-xl bg-slate-900 px-8 py-4 text-lg font-bold text-white hover:bg-slate-800 transition-colors shadow-lg">
          ⭐ View on GitHub
        </a>
        <a href="/#pricing"
           class="rounded-xl bg-indigo-600 px-8 py-4 text-lg font-bold text-white hover:bg-indigo-700 transition-colors shadow-lg">
          Get Lifetime Deal — $199
        </a>
      </div>
    </div>

    <!-- Cross-link to one-time alternative -->
    <div class="mb-10 text-center">
      <a
        href={`/one-time-alternative/${info.slug}`}
        class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-5 py-2 text-sm font-semibold text-green-700 hover:bg-green-100 transition-colors"
      >
        💰 Also looking for a one-time payment alternative to {info.name}? →
      </a>
    </div>

    <!-- Freedom Checker Widget -->
    <div class="mb-20 rounded-3xl border border-indigo-100 bg-gradient-to-br from-indigo-50 to-slate-50 p-8 md:p-12 shadow-xl">
      <div class="mb-8 text-center">
        <h2 class="text-3xl font-extrabold text-slate-900">
          🔓 Do You Need Open Source?
        </h2>
        <p class="mt-2 text-slate-500">
          Check everything that matters to you. We'll tell you if RefearnApp is your match.
        </p>
      </div>

      <div class="space-y-3 mb-8" id="freedom-checklist">
        {freedomItems.map((item) => (
          <label
            class="freedom-item flex cursor-pointer items-start gap-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-indigo-300"
            data-id={item.id}
          >
            <div class="relative mt-0.5 flex-shrink-0">
              <input
                type="checkbox"
                class="freedom-checkbox peer h-5 w-5 cursor-pointer appearance-none rounded border-2 border-slate-300 checked:border-indigo-600 checked:bg-indigo-600 transition-colors"
                data-id={item.id}
              />
              <svg class="pointer-events-none absolute inset-0 hidden h-5 w-5 text-white peer-checked:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="text-sm font-medium text-slate-700 leading-relaxed">{item.label}</span>
          </label>
        ))}
      </div>

      <!-- Score Result -->
      <div class="rounded-2xl border border-indigo-200 bg-white p-6 text-center shadow-sm">
        <p class="text-sm text-slate-500 mb-2">Your open source needs</p>
        <div class="flex items-center justify-center gap-4 mb-4">
          <div class="text-5xl font-extrabold text-indigo-600" id="score-number">0</div>
          <div class="text-2xl text-slate-400 font-bold">/ 5</div>
        </div>
        <div class="mb-4 h-3 rounded-full bg-slate-100 overflow-hidden">
          <div class="h-3 rounded-full bg-indigo-600 transition-all duration-500" id="score-bar" style="width: 0%"></div>
        </div>
        <p class="text-lg font-bold text-slate-900" id="score-message">
          Check what matters to you above
        </p>
        <p class="mt-1 text-sm text-slate-500" id="score-sub">
          RefearnApp covers all 5 open source needs out of the box
        </p>
        <div id="cta-reveal" class="hidden mt-6">
          <a href="/#pricing"
             class="inline-flex items-center gap-2 rounded-xl bg-indigo-600 px-6 py-3 font-bold text-white hover:bg-indigo-700 transition-colors">
            Get RefearnApp — Perfect Match 🎯
          </a>
        </div>
      </div>
    </div>

    <!-- Problem vs Solution -->
    <div class="mb-20 grid gap-6 md:grid-cols-2 md:gap-8">
      <div class="rounded-2xl border border-red-100 bg-red-50 p-6 shadow-sm md:p-8">
        <h3 class="mb-4 text-xl font-bold text-red-700">
          {info.name} — Closed Source Problems
        </h3>
        <ul class="space-y-4 text-red-900/80">
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            {info.weakness}
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            Proprietary black box — you can't verify how your tracking actually works.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            Your affiliate data is locked in their servers — no self-hosting option.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold mt-0.5">✕</span>
            If they shut down or raise prices, you have no way out.
          </li>
        </ul>
      </div>

      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-6 shadow-sm md:p-8">
        <h3 class="mb-4 text-xl font-bold text-blue-700">
          RefearnApp — Fully Open Source
        </h3>
        <ul class="space-y-4 text-blue-900/80">
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            Full source code on GitHub — inspect every line before you trust it with your business.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            {/* FIX 2: no "modify" language — just deploy and run */}
            Deploy to your own servers with our step-by-step docs — no dev work needed, just run the setup scripts.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            Self-hostable — your servers, your data, your rules. Migrate anytime.
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-blue-600 mt-0.5">✓</span>
            We handle all updates and improvements — you just stay on the latest version.
          </li>
        </ul>
      </div>
    </div>

    <!-- FIX 3: Self-host docs callout -->
    <div class="mb-16 rounded-2xl border border-indigo-100 bg-indigo-50 p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <h3 class="font-bold text-slate-900 mb-1">Want to self-host RefearnApp?</h3>
        <p class="text-sm text-slate-500">
          Our documentation walks you through the full setup. No dev work required —
          just follow the steps, run the setup scripts, and you're live on your own server.
        </p>
      </div>
      <a href="https://refearnapp.com/docs" class="flex-shrink-0 rounded-xl border border-indigo-300 bg-white px-5 py-2.5 text-sm font-bold text-indigo-700 hover:bg-indigo-100 transition-colors whitespace-nowrap">
        Read the Docs →
      </a>
    </div>

    <!-- Feature Comparison Table -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-extrabold text-slate-900">
        {info.name} vs RefearnApp — Open Source Comparison
      </h2>
      <div class="overflow-x-auto rounded-3xl border border-slate-200 bg-white shadow-xl">
        <table class="w-full min-w-[700px] border-collapse text-left text-sm md:text-base">
          <thead>
          <tr class="border-b border-slate-200 bg-slate-50/50">
            <th class="p-6 font-bold tracking-wider text-slate-500 uppercase">Feature</th>
            <th class="p-6 font-bold tracking-wider text-slate-400 uppercase">{info.name}</th>
            <th class="bg-indigo-50/50 p-6 font-bold tracking-wider text-indigo-600 uppercase">RefearnApp</th>
          </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
          <tr>
            <td class="p-6 font-semibold text-slate-900">Source Code Access</td>
            <td class="p-6 text-red-500 font-semibold">Closed Source</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-indigo-700">Open Source (AGPL v3)</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">GitHub Repository</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Self-Hosting</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Self-Host Documentation</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 font-bold text-indigo-700">
              <a href="https://refearnapp.com/docs" class="underline hover:text-indigo-900">refearnapp.com/docs</a>
            </td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Data Sovereignty</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Vendor Lock-In</td>
            <td class="p-6 text-red-500 font-semibold">Yes — trapped</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-green-600">None — total freedom</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Pricing Model</td>
            <td class="p-6 text-red-500 font-semibold">{info.price} subscription</td>
            <td class="bg-indigo-50/30 p-6 font-bold text-green-700">$199 one-time or free self-host</td>
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Unlimited Affiliates</td>
            <td class="p-6 text-slate-500">Limited on lower tiers</td>
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Stripe & Paddle Support</td>
            <td class="p-6 text-slate-500">Stripe only or expensive add-on</td>
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          <tr>
            <td class="p-6 font-semibold text-slate-900">Coupon Code Tracking</td>
            <td class="p-6 text-slate-400" set:html={crossIcon} />
            <td class="bg-indigo-50/30 p-6 text-indigo-600" set:html={checkIcon} />
          </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-center text-xs text-slate-400 italic md:hidden">← Swipe to compare →</p>
    </div>

    <!-- FAQ -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-3xl font-extrabold text-slate-900">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {[
          {
            q: `Is RefearnApp really open source unlike ${info.name}?`,
            a: `Yes. RefearnApp is fully open source under the AGPL v3 license. The complete source code is available on GitHub. ${info.name} is proprietary closed-source software — you have no visibility into how it works.`
          },
          {
            q: `Can I self-host RefearnApp on my own servers?`,
            a: `Yes. RefearnApp is fully self-hostable. Follow the setup guide at refearnapp.com/docs — no dev work required, just run the setup scripts and you are live. You can also start on our managed cloud and migrate to your own servers at any time.`
          },
          {
            q: `Do I need to be a developer to self-host RefearnApp?`,
            a: `No. Our documentation at refearnapp.com/docs walks you through every step. You just follow the guide and run a few setup scripts. We handle all updates and improvements so you never need to touch the code.`
          },
          {
            q: `What license does RefearnApp use?`,
            a: `RefearnApp uses the AGPL v3 (GNU Affero General Public License version 3). This means you can inspect the code, self-host it, and deploy it on your own servers freely.`
          },
          {
            q: `Does open source mean it is free to use?`,
            a: `You can self-host RefearnApp for free using the open source code — see refearnapp.com/docs for the setup guide. If you prefer a managed cloud version with support and guaranteed uptime, that is available as a one-time payment of $199 for Pro or $299 for Ultimate — no monthly subscription.`
          },
        ].map((faq) => (
          <details class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm cursor-pointer">
            <summary class="flex items-center justify-between font-semibold text-slate-900 list-none">
              {faq.q}
              <svg class="w-5 h-5 text-slate-400 group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <p class="mt-4 text-slate-600 leading-relaxed">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>

    <!-- Interlinked open source pages -->
    <div class="mb-16">
      <h3 class="mb-4 text-center text-xl font-bold text-slate-900">
        More Open Source Alternatives
      </h3>
      <p class="mb-8 text-center text-slate-500 text-sm">
        RefearnApp replaces every closed-source affiliate tool
      </p>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4">
        {otherCompetitors.map((c) => (
          <a
            href={`/open-source-alternative/${c.slug}`}
            class="flex flex-col items-center justify-center rounded-xl border border-slate-200 bg-white p-4 text-center text-sm font-semibold text-slate-600 transition-all hover:border-indigo-600 hover:text-indigo-600 hover:shadow-sm"
          >
            <span>{c.name}</span>
            <span class="mt-1 text-xs font-normal text-red-400">Closed Source</span>
          </a>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="mb-24 rounded-3xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-10 text-center shadow-2xl">
      <h2 class="mb-4 text-3xl font-extrabold text-white md:text-4xl">
        Stop Trusting a Black Box With Your Affiliate Data
      </h2>
      <p class="mb-8 text-indigo-200 text-lg">
        RefearnApp is open source, self-hostable and yours forever.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://github.com/ZAK123DSFDF/refearnapp" target="_blank" rel="noopener noreferrer"
           class="rounded-xl bg-white px-8 py-4 text-lg font-bold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-lg">
          ⭐ Star on GitHub
        </a>
        <a href="/#pricing"
           class="rounded-xl border border-indigo-400 px-8 py-4 text-lg font-semibold text-white hover:bg-indigo-700 transition-colors">
          Get Managed Cloud — $199 Lifetime
        </a>
      </div>
      <p class="mt-6 text-indigo-300 text-sm">AGPL v3 · Self-hostable · One-time payment · No lock-in</p>
    </div>

  </main>
  <Footer />
</Layout>

<script define:vars={{ totalItems: freedomItems.length }}>
  const checkboxes = document.querySelectorAll('.freedom-checkbox');
  const scoreNumber = document.getElementById('score-number');
  const scoreBar = document.getElementById('score-bar');
  const scoreMessage = document.getElementById('score-message');
  const scoreSub = document.getElementById('score-sub');
  const ctaReveal = document.getElementById('cta-reveal');
  const items = document.querySelectorAll('.freedom-item');

  const messages = {
    0: { msg: 'Check what matters to you above', sub: 'RefearnApp covers all 5 open source needs out of the box', cta: false },
    1: { msg: 'You have open source needs — RefearnApp can help', sub: 'Keep checking to see your full match', cta: false },
    2: { msg: 'RefearnApp covers your needs ✓', sub: 'You need more control than closed-source tools offer', cta: false },
    3: { msg: 'Strong match — RefearnApp fits well ✓', sub: 'Open source and self-hosting are clearly important to you', cta: false },
    4: { msg: 'Excellent match — RefearnApp is built for you ✓', sub: 'You need full control and RefearnApp delivers it', cta: true },
    5: { msg: 'Perfect match — RefearnApp covers everything 🎯', sub: 'You need open source and RefearnApp is the only affiliate tool that delivers all 5', cta: true },
  };

  function updateScore() {
    const checked = document.querySelectorAll('.freedom-checkbox:checked').length;
    const pct = (checked / totalItems) * 100;

    scoreNumber.textContent = checked;
    scoreBar.style.width = `${pct}%`;

    const state = messages[checked];
    scoreMessage.textContent = state.msg;
    scoreSub.textContent = state.sub;

    if (state.cta) {
      ctaReveal.classList.remove('hidden');
    } else {
      ctaReveal.classList.add('hidden');
    }

    items.forEach((item) => {
      const cb = item.querySelector('input[type="checkbox"]');
      if (cb && cb.checked) {
        item.classList.add('border-indigo-400', 'bg-indigo-50/50');
        item.classList.remove('border-slate-200', 'bg-white');
      } else {
        item.classList.remove('border-indigo-400', 'bg-indigo-50/50');
        item.classList.add('border-slate-200', 'bg-white');
      }
    });
  }

  checkboxes.forEach((cb) => cb.addEventListener('change', updateScore));
</script>

<style>
    details summary::-webkit-details-marker { display: none; }
</style>
---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/competitors';
---

<Layout
  title="Open Source Affiliate Software — Free & Open Source Alternatives to Closed SaaS Tools"
  description="Stop using closed-source affiliate tools. RefearnApp is the open-source alternative to Rewardful, FirstPromoter, Tolt and more. Inspect the code, self-host, own your data."
>
  <Header />

  <main class="mx-auto max-w-5xl px-4 py-12 md:px-6 md:py-24">
    <div class="mt-8 mb-16 text-center">
      <div class="mb-4 inline-flex items-center gap-2 rounded-full bg-indigo-50 border border-indigo-200 px-4 py-1.5 text-sm font-semibold text-indigo-700">
        🔓 Open Source · AGPL v3 · Self-Hostable · No Lock-In
      </div>
      <h1 class="mt-4 mb-6 text-4xl font-extrabold tracking-tight text-slate-900 md:text-6xl">
        Open Source<br />
        <span class="text-primary">Affiliate Software</span>
      </h1>
      <p class="mx-auto max-w-2xl text-xl leading-relaxed text-slate-600">
        Every major affiliate tool is a black box — you can't see the code, you can't move your data, you can't leave without pain.
        RefearnApp is <strong>fully open source</strong> under AGPL v3. Inspect it, deploy it yourself, own it completely.
      </p>
    </div>

    <!-- Why Open Source Matters -->
    <div class="mb-16 grid gap-4 sm:grid-cols-3">
      {[
        { icon: '🔍', title: 'Inspect the Code', desc: 'Know exactly how your affiliate tracking works. No hidden logic, no black box.' },
        { icon: '🖥️', title: 'Self-Host Anytime', desc: 'Start on our cloud, migrate to your own servers whenever you want. Full self-hosting docs available.' },
        { icon: '🔓', title: 'No Vendor Lock-In', desc: 'Your data is always yours. Deploy anywhere, migrate freely — total control with zero dependency.' },
      ].map((item) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm">
          <div class="mb-3 text-4xl">{item.icon}</div>
          <h3 class="mb-2 font-bold text-slate-900">{item.title}</h3>
          <p class="text-sm text-slate-500">{item.desc}</p>
        </div>
      ))}
    </div>

    <!-- All competitor cards -->
    <div class="mb-20">
      <h2 class="mb-8 text-center text-2xl font-bold text-slate-900">
        Open Source Alternative To Every Major Affiliate Tool
      </h2>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {competitors.map((c) => (
          <a
            href={`/open-source-alternative/${c.slug}`}
            class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm hover:border-indigo-400 hover:shadow-md transition-all"
          >
            <!-- FIX 1: changed to flex-col so badge never overlaps the name -->
            <div class="mb-3 flex flex-col gap-2">
              <div class="flex items-start justify-between gap-2">
                <h3 class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors leading-tight">
                  {c.name} Alternative
                </h3>
                <!-- FIX 1: flex-shrink-0 keeps badge from wrapping awkwardly -->
                <span class="flex-shrink-0 rounded-full bg-red-50 px-2 py-0.5 text-xs font-semibold text-red-500 whitespace-nowrap self-start">
                  Closed Source
                </span>
              </div>
            </div>
            <p class="mb-4 text-sm text-slate-500">
              Open source alternative with full code access and self-hosting
            </p>
            <div class="rounded-lg bg-indigo-50 border border-indigo-100 px-3 py-2 text-center">
              <span class="text-sm font-bold text-indigo-600">🔓 View Open Source Alternative →</span>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Self-host docs callout -->
    <div class="mb-16 rounded-2xl border border-indigo-100 bg-indigo-50 p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div>
        <h3 class="font-bold text-slate-900 mb-1">Want to self-host RefearnApp?</h3>
        <p class="text-sm text-slate-500">Our documentation walks you through the full setup — no coding experience needed. Just run a few scripts and you're live.</p>
      </div>
      <a href="https://refearnapp.com/docs" class="flex-shrink-0 rounded-xl border border-indigo-300 bg-white px-5 py-2.5 text-sm font-bold text-indigo-700 hover:bg-indigo-100 transition-colors whitespace-nowrap">
        Read the Docs →
      </a>
    </div>

    <!-- CTA -->
    <div class="rounded-3xl bg-gradient-to-br from-indigo-600 to-indigo-800 p-10 text-center shadow-2xl">
      <h2 class="mb-4 text-3xl font-extrabold text-white">Own Your Affiliate Stack</h2>
      <p class="mb-8 text-indigo-200 text-lg">
        Open source, self-hostable, one-time payment. Built for founders who want control.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://github.com/ZAK123DSFDF/refearnapp" target="_blank" rel="noopener noreferrer"
           class="rounded-xl bg-white px-8 py-4 text-lg font-bold text-indigo-700 hover:bg-indigo-50 transition-colors shadow-lg">
          ⭐ View on GitHub
        </a>
        <a href="/#pricing"
           class="rounded-xl border border-indigo-400 px-8 py-4 text-lg font-semibold text-white hover:bg-indigo-700 transition-colors">
          Get Lifetime Deal — $199
        </a>
      </div>
    </div>

  </main>
  <Footer />
</Layout>